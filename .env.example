# Gemini image generation
GEMINI_API_KEY=your-google-ai-studio-api-key

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Public URL where this app is hosted (used for OAuth callback)
PUBLIC_URL=https://paperbanana-generator.vizuara.ai

# Comma-separated list of emails allowed to sign in
ALLOWED_EMAILS=rajatdandekar@vizuara.com

# Long random string for session cookie signing
SESSION_SECRET=replace-me-with-a-long-random-string

# Server port (default 3000)
PORT=3000

# Optional: override the Gemini image model
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
